# ========================================
# TIMETASTIC-TOGGL SYNC CONFIGURATION
# ========================================
# Copy this file to .env and fill in your values

# ========================================
# API CONFIGURATION
# ========================================

# Toggl Track API
TOGGL_BASE_URL=https://api.track.toggl.com/api/v9
TOGGL_REPORTS_BASE_URL=https://api.track.toggl.com/reports/api/v3
TOGGL_API_TOKEN=your_toggl_api_token_here

# Timetastic API
TIMETASTIC_BASE_URL=https://app.timetastic.co.uk/api
TIMETASTIC_API_TOKEN=your_timetastic_api_token_here

# === Default logic ===
DEFAULT_DAILY_HOURS=8
WORKSPACE_ID=

# ========================================
# SLACK INTEGRATION
# ========================================

# Slack Bot Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_DEFAULT_SENDER_NAME=MillarcAI
SLACK_DM_FALLBACK_CHANNEL=general
SLACK_ORG_EMAIL_DOMAIN=millarcgroup.slack.com

# Slack Notification Schedule
SLACK_NOTIFICATION_DAY=Friday
SLACK_NOTIFICATION_TIME=09:00

# ========================================
# ACCESS CONTROL
# ========================================

# Admin emails (comma-separated) - have access to all reports
ADMIN_EMAILS=admin@company.com,hr@company.com

# Producer emails (comma-separated) - have access to project reports only
PRODUCER_EMAILS=producer1@company.com,producer2@company.com

# Optional: Run token for CLI/cron security (can be empty)
RUN_TOKEN=

# ========================================
# EXPORTS AND STORAGE
# ========================================

# Directory for exports (reports, CSV files, etc.)
EXPORTS_DIR=./exports
# Database file for local caching (SQLite)
DATABASE_PATH=./data/sync.db

# ========================================
# NOTIFICATION SETTINGS
# ========================================

# Days to check back for missing time entries (default: 7)
MISSING_ENTRIES_CHECK_DAYS=7

# Send notifications for missing entries
SEND_MISSING_ENTRIES_NOTIFICATIONS=true

# Send monthly reports to users
SEND_MONTHLY_REPORTS=true

# Send admin notifications
SEND_ADMIN_NOTIFICATIONS=true

# ========================================
# DEBUGGING AND LOGGING
# ========================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path (leave empty for console only)
LOG_FILE=

# ========================================
# TESTING (Optional)
# ========================================

# Test user IDs for Slack testing
SLACK_TEST_USER_ID=
SLACK_TEST_EMAIL=


# Test date ranges
TOGGL_TEST_START_DATE=2025-10-01
TOGGL_TEST_END_DATE=2025-10-16
TOGGL_TEST_USER_ID=

TIMETASTIC_TEST_START_DATE=2025-10-01
TIMETASTIC_TEST_END_DATE=2025-10-16
TIMETASTIC_TEST_USER_ID=
